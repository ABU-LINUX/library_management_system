{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/next"
        },
        {
            "src": "backend/app.py",
            "use": "@vercel/python",
            "config": {
                "includeFiles": [
                    "frontend/**",
                    "config/**",
                    "receipts/**"
                ]
            }
        }
    ],
    "routes": [
        { "src": "/champions(.*)", "dest": "/champions$1" },
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/_next/(.*)", "dest": "/_next/$1" },
        { "src": "/(.*)", "dest": "backend/app.py" }
    ],
    "crons": [
        {
            "path": "/api/cron/send_reminders",
            "schedule": "0 9 * * *"
        }
    ]
}