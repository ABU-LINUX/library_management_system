{
    "version": 2,
    "builds": [
        {
            "src": "backend/app.py",
            "use": "@vercel/python",
            "config": {
                "includeFiles": [
                    "frontend/**",
                    "config/**",
                    "receipts/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "backend/app.py"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/send_reminders",
            "schedule": "0 9 * * *"
        }
    ]
}